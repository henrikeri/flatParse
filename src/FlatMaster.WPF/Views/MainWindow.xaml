<Window x:Class="FlatMaster.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlatMaster - Astronomical Flat Calibration Orchestrator"
        Height="900" Width="1600" MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with modern gradient and branding -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" BorderThickness="0,0,0,1" 
                BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="24,16,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo & Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FM" FontSize="26" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FlatMaster" FontSize="22" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Flat Calibration Orchestrator" FontSize="11" 
                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status & Progress -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" 
                               Foreground="{StaticResource AccentBrush}" FontWeight="Medium"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Tab Content -->
        <Grid Grid.Row="1" Margin="0">
            <TabControl Background="{StaticResource WindowBackgroundBrush}" 
                        BorderThickness="0"
                        Foreground="{StaticResource PrimaryTextBrush}">
                <TabControl.Resources>
                    <!-- Custom tab styling for modern look -->
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,12"/>
                        <Setter Property="Margin" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="BorderThickness" Value="0,2,0,0"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <!-- Configuration Tab -->
                <TabItem Padding="16,12" Margin="0">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding ConfigurationTabStepBrush}" Margin="0,0,6,0">
                                <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center" LineHeight="18"/>
                            </Border>
                            <TextBlock Text="Configuration" VerticalAlignment="Center"/>
                            <TextBlock Text="  ->" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,24,24,24">
                        <StackPanel>
                            <!-- PixInsight Settings (hidden when native processing is enabled) -->
                            <StackPanel Visibility="{Binding UseNativeProcessing, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        IsEnabled="{Binding IsNotDarksOnlyMode}">
                                <TextBlock Text="PixInsight Executable" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding PixInsightPath, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" Margin="0,0,8,0" FontSize="12"
                                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                             Background="{StaticResource InputBackgroundBrush}"/>
                                    <Button Grid.Column="1" Content="Browse" Width="90" Height="38"
                                            Command="{Binding BrowsePixInsightCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Output Configuration -->
                            <TextBlock Text="Output Configuration" FontSize="14" FontWeight="SemiBold" 
                                       IsEnabled="{Binding IsNotDarksOnlyMode}"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                    Background="{StaticResource PanelBackgroundBrush}" Padding="16" CornerRadius="4"
                                    IsEnabled="{Binding IsNotDarksOnlyMode}"
                                    Margin="0,0,0,24">
                                <StackPanel>
                                    <RadioButton Content="Put processed files in source directories" 
                                                 IsChecked="{Binding UseReplicatedOutput, Converter={StaticResource InverseBoolConverter}}"
                                                 Margin="0,0,0,12" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <RadioButton Content="Create separate output tree with replicated structure" 
                                                 IsChecked="{Binding UseReplicatedOutput}"
                                                 Margin="0,0,0,16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    
                                    <TextBlock Text="Output Root Directory" FontSize="12" 
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding OutputRootPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="12,10" Margin="0,0,8,0" FontSize="12"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 Background="{StaticResource InputBackgroundBrush}"/>
                                        <Button Grid.Column="1" Content="Browse" Width="90" Height="38"
                                                Command="{Binding BrowseOutputDirectoryCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </Grid>

                                    <DockPanel LastChildFill="False" Margin="0,12,0,0">
                                        <TextBlock Text="Export Format" FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding OutputFormatOptions}"
                                                  SelectedItem="{Binding OutputFormat, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="120" Margin="12,0,0,0" Padding="6,2"/>
                                    </DockPanel>

                                    <CheckBox Content="Only copy processed files (skip non-image files)" 
                                              IsChecked="{Binding CopyOnlyProcessed}"
                                              Margin="0,16,0,0" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Data Roots -->
                            <TextBlock Text="Data Roots" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        IsEnabled="{Binding IsNotDarksOnlyMode}"
                                        Background="{StaticResource PanelBackgroundBrush}" Padding="12" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="Flat Base Directories" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                        <ListBox x:Name="FlatRootsList"
                                                 ItemsSource="{Binding FlatBaseRoots}" Height="90" Margin="0,0,0,10"
                                                 IsSynchronizedWithCurrentItem="True"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Background="{StaticResource PanelBackgroundBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <UniformGrid Rows="1" Columns="2">
                                            <Button Content="+ Add Directory" Command="{Binding AddFlatRootCommand}"
                                                    Margin="0,0,6,0" Style="{StaticResource PrimaryButtonStyle}"/>
                                            <Button Content="- Remove" Command="{Binding RemoveFlatRootCommand}"
                                                    CommandParameter="{Binding ElementName=FlatRootsList, Path=SelectedItem}"
                                                    Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Background="{StaticResource PanelBackgroundBrush}" Padding="12" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="Dark Library Directories" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                        <ListBox x:Name="DarkRootsList"
                                                 ItemsSource="{Binding DarkLibraryRoots}" Height="90" Margin="0,0,0,10"
                                                 IsSynchronizedWithCurrentItem="True"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Background="{StaticResource PanelBackgroundBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <UniformGrid Rows="1" Columns="2">
                                            <Button Content="+ Add Directory" Command="{Binding AddDarkRootCommand}"
                                                    Margin="0,0,6,0" Style="{StaticResource PrimaryButtonStyle}"/>
                                            <Button Content="- Remove" Command="{Binding RemoveDarkRootCommand}"
                                                    CommandParameter="{Binding ElementName=DarkRootsList, Path=SelectedItem}"
                                                    Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Processing Options -->
                            <TextBlock Text="Processing Options" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource PanelBackgroundBrush}" Padding="12" CornerRadius="4">
                                <StackPanel>
                                    <CheckBox Content="Use Native Processing Engine (no external dependencies)"
                                              IsChecked="{Binding UseNativeProcessing}"
                                              Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                    <CheckBox Content="Darks-only process mode (build master darks only)"
                                              IsChecked="{Binding DarksOnlyProcessMode}"
                                              Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                                    <CheckBox Content="Delete calibrated flats after creating master (saves disk space)"
                                              IsChecked="{Binding DeleteCalibrated}"
                                              IsEnabled="{Binding IsNotDarksOnlyMode}"
                                              Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                                    <CheckBox Content="Require darks (skip missing, log as failed)"
                                              IsChecked="{Binding RequireDarks}"
                                              IsEnabled="{Binding IsNotDarksOnlyMode}"
                                              Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                                    <TextBlock Text="Bias fallback guard:"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,6"/>
                                    <TextBlock Text="If the selected dark exceeds either delta limit, a bias will be selected."
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>

                                    <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                        <TextBlock Text="Temperature delta limit (degrees C):"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding DarkOverBiasTempDeltaC, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                                 Width="72" Margin="10,0,0,0" Padding="6,2"
                                                 HorizontalContentAlignment="Right"/>
                                    </DockPanel>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="Exposure delta limit (seconds):"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding DarkOverBiasExposureDeltaSeconds, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                                 Width="72" Margin="10,0,0,0" Padding="6,2"
                                                 HorizontalContentAlignment="Right"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Scanning Tab -->
                <TabItem Padding="16,12" Margin="0">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding ScanTabStepBrush}" Margin="0,0,6,0">
                                <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center" LineHeight="18"/>
                            </Border>
                            <TextBlock Text="Scan" VerticalAlignment="Center"/>
                            <TextBlock Text="  ->" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Action Buttons -->
                        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" 
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" Padding="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Scan Button -->
                                <Button Grid.Row="0" Grid.Column="0"
                                        Content="{Binding ScanButtonText}"
                                        Command="{Binding ScanAllCommand}"
                                        IsEnabled="{Binding CanScanAll}"
                                        Style="{StaticResource PrimaryButtonStyle}" Height="44" FontSize="13"
                                        Margin="0,0,12,0"/>

                                <!-- Scan Progress -->
                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding FlatScanProgressText}" FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                                        <ProgressBar Height="4" Maximum="1"
                                                     Value="{Binding FlatScanProgressValue}"
                                                     IsIndeterminate="{Binding IsFlatScanActive}"
                                                     Foreground="{StaticResource AccentBrush}" Background="#E0E0E0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding DarkScanProgressText}" FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                                        <ProgressBar Height="4" Maximum="1"
                                                     Value="{Binding DarkScanProgressValue}"
                                                     IsIndeterminate="{Binding IsDarkScanActive}"
                                                     Foreground="{StaticResource AccentBrush}" Background="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Abort Button (only visible when operation is running) -->
                                <Button Grid.Row="0" Grid.Column="1" Content="Abort" 
                                        Command="{Binding CancelOperationCommand}"
                                        Visibility="{Binding IsCancellable, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#D32F2F" Foreground="White" BorderBrush="#B71C1C"
                                        Height="44" FontSize="13" FontWeight="Bold" Padding="24,0"
                                        Margin="12,0,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                BorderThickness="1" 
                                                                CornerRadius="6" 
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E53935"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#C62828"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Results Grid -->
                        <Grid Grid.Row="1" Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Flats -->
                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    IsEnabled="{Binding IsNotDarksOnlyMode}"
                                    Background="{StaticResource PanelBackgroundBrush}" CornerRadius="4">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" 
                                            BorderBrush="{StaticResource BorderBrush}" Padding="16,12">
                                        <DockPanel>
                                            <TextBlock Text="Flat Directories Found" FontSize="13" FontWeight="SemiBold"
                                                       DockPanel.Dock="Left" VerticalAlignment="Center"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="All" Command="{Binding SelectAllFlatsCommand}" 
                                                    Width="80" Margin="0,0,6,0" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Content="Clear" Command="{Binding DeselectAllFlatsCommand}" 
                                                    Width="80" Style="{StaticResource SecondaryButtonStyle}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            Background="{StaticResource HeaderBackgroundBrush}" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Select" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Inventory Item" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>

                                    <TreeView ItemsSource="{Binding FlatDirectories}" BorderThickness="0" Margin="0" Padding="0">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding ExposureGroups}">
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#ECECEC" Padding="4,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding DirectoryPath}">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}  (Groups: {1}, Files: {2})">
                                                                    <Binding Path="DisplayPath" Mode="OneWay"/>
                                                                    <Binding Path="GroupCount" Mode="OneWay"/>
                                                                    <Binding Path="FileCount" Mode="OneWay"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <HierarchicalDataTemplate.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Files}">
                                                        <Border BorderThickness="0,0,0,1" BorderBrush="#F2F2F2" Padding="6,3" Background="#FCFCFC">
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Summary}"/>
                                                        </Border>
                                                        <HierarchicalDataTemplate.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="6,2">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                                               ToolTip="{Binding FullPath}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </HierarchicalDataTemplate.ItemTemplate>
                                                    </HierarchicalDataTemplate>
                                                </HierarchicalDataTemplate.ItemTemplate>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </DockPanel>
                            </Border>

                            <!-- Splitter -->
                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                                          Background="{StaticResource BorderBrush}"/>

                            <!-- Darks -->
                            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource PanelBackgroundBrush}" CornerRadius="4">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" 
                                            BorderBrush="{StaticResource BorderBrush}" Padding="16,12">
                                        <DockPanel>
                                            <TextBlock Text="Dark Frame Inventory" FontSize="13" FontWeight="SemiBold"
                                                       DockPanel.Dock="Left" VerticalAlignment="Center"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="All" Command="{Binding SelectAllDarksCommand}" 
                                                    Width="80" Margin="0,0,6,0" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Content="Clear" Command="{Binding DeselectAllDarksCommand}" 
                                                    Width="80" Style="{StaticResource SecondaryButtonStyle}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            Background="{StaticResource HeaderBackgroundBrush}" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Select" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Inventory Item" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>

                                    <TreeView ItemsSource="{Binding DarkInventory}" BorderThickness="0" Margin="0" Padding="0">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#ECECEC" Padding="4,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                    </Grid>
                                                </Border>
                                                <HierarchicalDataTemplate.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <Border BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="4,3" Background="#FCFCFC">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="56"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                            </Grid>
                                                        </Border>
                                                        <HierarchicalDataTemplate.ItemTemplate>
                                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                                <Border BorderThickness="0,0,0,1" BorderBrush="#F5F5F5" Padding="4,3">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="56"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource SecondaryTextBrush}"
                                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                                                    </Grid>
                                                                </Border>
                                                                <HierarchicalDataTemplate.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Padding="4,2">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="56"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="{StaticResource SecondaryTextBrush}"
                                                                                           FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </HierarchicalDataTemplate.ItemTemplate>
                                                            </HierarchicalDataTemplate>
                                                        </HierarchicalDataTemplate.ItemTemplate>
                                                    </HierarchicalDataTemplate>
                                                </HierarchicalDataTemplate.ItemTemplate>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Matching Diagnostics Tab -->
                <TabItem Padding="16,12" Margin="0"
                         IsEnabled="{Binding IsNotDarksOnlyMode}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding MatchingTabStepBrush}" Margin="0,0,6,0">
                                <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center" LineHeight="18"/>
                            </Border>
                            <TextBlock Text="Matching Details" VerticalAlignment="Center"/>
                            <TextBlock Text="  ->" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Diagnostic Summary -->
                        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" 
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" Padding="24">
                            <StackPanel>
                                <DockPanel>
                                    <Button Content="Run Matching" 
                                            Command="{Binding GenerateMatchingDiagnosticsCommand}"
                                            IsEnabled="{Binding IsGeneratingMatching, Converter={StaticResource InverseBoolConverter}}"
                                            DockPanel.Dock="Right" Style="{StaticResource AccentButtonStyle}" 
                                            Height="36" Padding="16,6" FontSize="13"/>
                                    <TextBlock Text="Match selected flat groups against selected darks. Use Override to force a specific master/loose-dark candidate." 
                                               FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                </DockPanel>

                                <StackPanel Margin="0,10,0,0"
                                            Visibility="{Binding IsGeneratingMatching, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="{Binding MatchingProgressText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   DockPanel.Dock="Left"/>
                                        <TextBlock Text="{Binding MatchingProgressValue, StringFormat={}{0:P0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <ProgressBar Value="{Binding MatchingProgressValue}"
                                                 Maximum="1.0"
                                                 Height="8"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Background="#E0E0E0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Diagnostic Tree Grid -->
                        <Grid Grid.Row="1" Margin="24">
                            <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource PanelBackgroundBrush}">
                                <DataGrid ItemsSource="{Binding MatchingGroups}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserSortColumns="True"
                                          CanUserResizeRows="False"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FAFAFA"
                                          AlternationCount="2"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          RowHeight="34"
                                          ColumnHeaderHeight="36"
                                          HorizontalGridLinesBrush="#ECECEC"
                                          VerticalGridLinesBrush="#F5F5F5"
                                          Margin="0">
                                    <DataGrid.Resources>
                                        <Style TargetType="{x:Type DataGridColumnHeader}">
                                            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,0,10,0"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                        <Style TargetType="{x:Type DataGridCell}">
                                            <Setter Property="Padding" Value="10,0,10,0"/>
                                            <Setter Property="BorderBrush" Value="#ECECEC"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding HasMinimumFrames}" Value="False">
                                                    <Setter Property="Background" Value="#FFD6D6"/>
                                                    <Setter Property="Foreground" Value="#7A0000"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasMinimumFrames}" Value="False"/>
                                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#FFD6D6"/>
                                                    <Setter Property="Foreground" Value="#7A0000"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="{x:Type ComboBox}">
                                            <Setter Property="MinHeight" Value="26"/>
                                            <Setter Property="Padding" Value="4,1"/>
                                        </Style>
                                        <Style x:Key="MatchingTextBaseStyle" TargetType="{x:Type TextBlock}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="Margin" Value="2,0,2,0"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                        <Style x:Key="MatchingTextLeftStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextBaseStyle}">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                        </Style>
                                        <Style x:Key="MatchingTextRightStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextBaseStyle}">
                                            <Setter Property="TextAlignment" Value="Right"/>
                                        </Style>
                                        <Style x:Key="MatchingTextCenterStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextBaseStyle}">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="{x:Type DataGridRow}">
                                            <Setter Property="DetailsVisibility" Value="Collapsed"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasMinimumFrames}" Value="True"/>
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#F4F8FD"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasMinimumFrames}" Value="True"/>
                                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#E8F2FF"/>
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding HasMinimumFrames}" Value="False">
                                                    <Setter Property="Background" Value="#FFD6D6"/>
                                                    <Setter Property="Foreground" Value="#7A0000"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                    <Setter Property="DetailsVisibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.RowDetailsTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="0,1,0,0" BorderBrush="#E8E8E8" Background="#FCFCFC" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FlatFiles.Count, StringFormat=Flat files in group: {0}}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               Margin="0,0,0,4"/>
                                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding FlatFiles}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" FontSize="11" Margin="0,1"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGrid.RowDetailsTemplate>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="36" CanUserSort="False">
                                            <DataGridTemplateColumn.CellStyle>
                                                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTemplateColumn.CellStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Width="18"
                                                                  Height="18"
                                                                  Padding="0"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Background="Transparent"
                                                                  BorderBrush="#D6D6D6"
                                                                  BorderThickness="1"
                                                                  Cursor="Hand">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton">
                                                                <Setter Property="Content" Value=">"/>
                                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter Property="Background" Value="#E6E6E6"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter Property="Content" Value="v"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                    </ToggleButton>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridCheckBoxColumn Header="Include"
                                                                Binding="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SortMemberPath="IsIncluded"
                                                                Width="70"
                                                                CanUserSort="True">
                                            <DataGridCheckBoxColumn.CellStyle>
                                                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridCheckBoxColumn.CellStyle>
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="{x:Type CheckBox}">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                            <DataGridCheckBoxColumn.EditingElementStyle>
                                                <Style TargetType="{x:Type CheckBox}">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridCheckBoxColumn.EditingElementStyle>
                                        </DataGridCheckBoxColumn>
                                        <DataGridTextColumn Header="Directory"
                                                            Binding="{Binding DirectoryPath}"
                                                            SortMemberPath="DirectoryPath"
                                                            Width="*"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextLeftStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding DirectoryPath}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Exposure (seconds)"
                                                            Binding="{Binding ExposureTime, StringFormat=F3}"
                                                            SortMemberPath="ExposureTime"
                                                            Width="130"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextRightStyle}"/>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Average Flat Temperature"
                                                            Binding="{Binding FlatAverageTemperatureDisplay}"
                                                            SortMemberPath="FlatAverageTemperatureSortValue"
                                                            Width="180"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextRightStyle}"/>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Files"
                                                            Binding="{Binding FileCount}"
                                                            SortMemberPath="FileCount"
                                                            Width="65"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextCenterStyle}"/>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Selected Dark"
                                                            Binding="{Binding SelectedDarkDisplay}"
                                                            SortMemberPath="SelectedDarkDisplay"
                                                            Width="250"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextLeftStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding SelectedDarkDisplay}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Reason"
                                                            Binding="{Binding SelectionReason}"
                                                            SortMemberPath="SelectionReason"
                                                            Width="180"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextLeftStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding SelectionReason}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Temperature Delta"
                                                            Binding="{Binding TemperatureDeltaDisplay}"
                                                            SortMemberPath="TemperatureDeltaSortValue"
                                                            Width="140"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextRightStyle}"/>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Confidence"
                                                            Binding="{Binding ConfidenceDisplay}"
                                                            SortMemberPath="ConfidenceSortValue"
                                                            Width="95"
                                                            IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MatchingTextCenterStyle}"/>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="Override" Width="260" CanUserSort="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding OverrideOptions}"
                                                              SelectedItem="{Binding SelectedOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="DisplayName"
                                                              MinWidth="240"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Processing & Report Tab -->
                <TabItem Padding="16,12" Margin="0">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="{Binding ProcessingTabStepBrush}" Margin="0,0,6,0">
                                <TextBlock Text="4" Foreground="White" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center" LineHeight="18"/>
                            </Border>
                            <TextBlock Text="Process &amp; Report" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Action Button -->
                        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" 
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" Padding="24">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Start Processing" 
                                        Command="{Binding ProcessSelectedCommand}"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"
                                        Style="{StaticResource AccentButtonStyle}" Height="44" FontSize="14" 
                                        Padding="24,10" HorizontalAlignment="Left"/>

                                <!-- Abort Button (only visible when processing) -->
                                <Button Content="Abort Processing" 
                                        Command="{Binding CancelOperationCommand}"
                                        Visibility="{Binding IsCancellable, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#D32F2F" Foreground="White" BorderBrush="#B71C1C"
                                        Height="44" FontSize="14" FontWeight="Bold" Padding="24,0"
                                        Margin="12,0,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                BorderThickness="1" 
                                                                CornerRadius="6" 
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E53935"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#C62828"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Batch Progress -->
                        <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" 
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}" 
                                Padding="24,14"
                                Visibility="{Binding ShowBatchProgress, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding BatchProgressText}" FontSize="13" FontWeight="SemiBold"
                                               DockPanel.Dock="Left" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{Binding TimeRemainingText}" FontSize="12"
                                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </DockPanel>
                                <ProgressBar Value="{Binding BatchProgressValue}" Maximum="1.0" Height="10"
                                             Foreground="{StaticResource AccentBrush}" Background="#E0E0E0"/>
                            </StackPanel>
                        </Border>

                        <!-- Report & Log -->
                        <Grid Grid.Row="2" Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Processing Report -->
                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource PanelBackgroundBrush}" CornerRadius="4">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" 
                                            BorderBrush="{StaticResource BorderBrush}" Padding="16,12">
                                        <TextBlock Text="Processing Report" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox Text="{Binding ProcessingReportText, Mode=OneWay}" 
                                                 IsReadOnly="True" TextWrapping="Wrap" FontSize="11"
                                                 FontFamily="Consolas" Padding="16" BorderThickness="0"
                                                 Background="Transparent" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <!-- Splitter -->
                            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" 
                                          Background="{StaticResource BorderBrush}"/>

                            <!-- Processing Log -->
                            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource PanelBackgroundBrush}" CornerRadius="4">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" 
                                            BorderBrush="{StaticResource BorderBrush}" Padding="16,12">
                                        <TextBlock Text="Processing Log" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox Text="{Binding LogText, Mode=OneWay}" 
                                                 IsReadOnly="True" TextWrapping="Wrap" FontSize="10"
                                                 FontFamily="Consolas" Padding="16" BorderThickness="0"
                                                 Background="#1E1E1E" Foreground="#D4D4D4"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBackgroundBrush}" 
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="FlatMaster v1.0.4" Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="|" Margin="12,0" Foreground="{StaticResource BorderBrush}"/>
                <TextBlock Text=".NET 8 + WPF" Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="|" Margin="12,0" Foreground="{StaticResource BorderBrush}"/>
                <TextBlock Text="PixInsight / Native Processing" Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="|" Margin="12,0" Foreground="{StaticResource BorderBrush}"/>
                <Button Content="Licenses" Click="OnLicensesClick"
                        Style="{StaticResource SecondaryButtonStyle}" FontSize="11"
                        Padding="10,2" MinHeight="24"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>


